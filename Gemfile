source "https://rubygems.org"

# GitHub Pages builds your site with this gem set — it pins Jekyll and all
# supported plugins to the exact versions GitHub uses, so "works locally =
# works when deployed".
gem "github-pages", group: :jekyll_plugins

# Plugins referenced in _config.yml
gem "jekyll-feed"
gem "jekyll-seo-tag"

# Windows / newer Ruby compatibility
gem "webrick"
